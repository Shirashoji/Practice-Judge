# docker compose用の環境変数（cp .env.example .env して編集する）
# ローカルで動かすだけなら未設定（デフォルト値）でも動く。

# セッションcookieの署名キー。本番では必ずランダムな値に変更すること。
SESSION_SECRET=

# CORSで許可するフロントのオリジン。
# 本番相当(compose.yamlのみ)のデフォルト: http://localhost:3000
# 開発(override込み)ではhttp://localhost:5173が自動で使われる。
FRONTURL=

# フロントのビルドに焼き込むAPIのURL（ブラウザから見えるURL）。
# デフォルト: http://localhost:8181
VITE_BASEURL=

# HTTPS付きの実デプロイ時のみ production を設定する。
# （http+localhostで設定するとsecure cookie強制によりログインできなくなる）
NODE_ENV=

# 開発モードのフロント公開ポート（他プロジェクトと5173が衝突する場合に変更）。
# デフォルト: 5173
FRONT_DEV_PORT=
